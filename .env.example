APP_BASE_URL=http://localhost:3000
DATA_DIR=./data

# Generate long random values for production:
# openssl rand -hex 32
PHONE_HASH_SECRET=replace-with-a-long-random-hmac-secret
PHONE_ENCRYPTION_KEY=replace-with-a-64-hex-character-key
ADMIN_TOKEN=replace-with-a-long-admin-token

# Optional Telegram integration
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ADMIN_ID=
TELEGRAM_WEBHOOK_SECRET=replace-with-a-long-webhook-secret

# Optional phone operator lookup for admin panel
NUMVERIFY_API_KEY=
# Leave empty for legacy Numverify endpoint, or set APILayer endpoint:
# NUMVERIFY_ENDPOINT=https://api.apilayer.com/number_verification/validate
NUMVERIFY_ENDPOINT=https://apilayer.net/api/validate

# Optional Inquerely number lookup for admin panel
INQUERELY_API_KEY=
INQUERELY_SEARCH_ENDPOINT=https://inquerely.com/api/v1/search
