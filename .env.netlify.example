# TirageZone - variables Netlify
# A mettre dans Netlify > Site configuration > Environment variables

# URL publique de ton site Netlify.
# Exemple: https://tiragezone.netlify.app
NEXT_PUBLIC_SITE_URL=
SITE_URL=

# Stockage serverless Netlify.
# Laisse /tmp/data sur Netlify.
DATA_DIR=/tmp/data

# Secrets obligatoires pour protéger les numéros.
# PHONE_HASH_SECRET: long secret aleatoire.
# Exemple de generation: openssl rand -hex 32
PHONE_HASH_SECRET=

# PHONE_ENCRYPTION_KEY: cle hex de 64 caracteres.
# Exemple de generation: openssl rand -hex 32
PHONE_ENCRYPTION_KEY=

# Cle admin pour le panel /admin.
# Exemple de generation: openssl rand -hex 32
ADMIN_TOKEN=

# Discord bot.
# DISCORD_BOT_TOKEN: token du bot Discord.
# DISCORD_CHANNEL_ID: identifiant du salon ou recevoir les embeds.
# DISCORD_ADMIN_ID: ton identifiant Discord autorise a cliquer les boutons.
# DISCORD_PUBLIC_KEY: Public Key de l'application Discord.
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
DISCORD_ADMIN_ID=
DISCORD_PUBLIC_KEY=

# Lookup operateur telephonique.
# Optionnel si tu n'utilises pas Numverify.
NUMVERIFY_API_KEY=
NUMVERIFY_ENDPOINT=https://apilayer.net/api/validate

# Lookup Inquerely.
# Optionnel si tu n'utilises pas le bouton Lookup.
INQUERELY_API_KEY=
INQUERELY_SEARCH_ENDPOINT=https://inquerely.com/api/v1/search
